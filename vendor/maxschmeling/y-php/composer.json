{
    "name": "maxschmeling/y-php",
    "description": "Fresh PHP implementation of Yjs-compatible CRDT primitives targeting binary compatibility with Yjs 13.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Yjs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yjs\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "proof": "php examples/proof-of-life.php",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
