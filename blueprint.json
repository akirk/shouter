{
  "landingPage": "/wp-admin/post-new.php",
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "gutenberg"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/akirk/shouter",
        "ref": "HEAD"
      },
      "options": {
        "activate": true,
        "targetFolderName": "shouter"
      },
      "progress": {
        "caption": "Installing plugin from GitHub: akirk/shouter"
      }
    },
    {
      "step": "defineWpConfigConsts",
      "consts": {
        "WP_ALLOW_COLLABORATION": true
      }
    },
    {
      "step": "runPHP",
      "code": "<?php require_once '/wordpress/wp-load.php'; $data = array( 'user_login' => 'shouter', 'user_pass' => 'password', 'role' => 'administrator', 'display_name' => 'Shouter',); wp_insert_user( $data ); ?>",
      "progress": {
        "caption": "createUser: shouter"
      }
    },
    {
      "step": "setSiteOptions",
      "options": {
        "shouter_bot_user_id": "2"
      }
    }
  ],
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Shouter",
    "author": "https://github.com/akirk/playground-step-library"
  }
}
